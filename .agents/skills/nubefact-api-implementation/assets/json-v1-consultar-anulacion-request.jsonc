{
  // Operation type - always "consultar_anulacion" for checking void status
  "operacion": "consultar_anulacion",

  // Document type: 1=Factura, 2=Boleta, 3=Nota de Crédito, 4=Nota de Débito
  "tipo_de_comprobante": 1,

  // Series of voided document (4 characters exact)
  "serie": "FFF1",

  // Number of voided document (1-8 digits, no leading zeros)
  "numero": 1
}
