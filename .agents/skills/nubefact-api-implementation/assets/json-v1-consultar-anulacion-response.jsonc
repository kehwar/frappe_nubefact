{
  // Sequential void request number
  "numero": 1,

  // NubeFact web link to view the void request
  "enlace": "https://www.nubefact.com/anulacion/b7fc0c001-b31a",

  // SUNAT ticket number for async void processing (string)
  "sunat_ticket_numero": "1494358661332",

  // Whether SUNAT has accepted the void (boolean, check this to know if void is complete)
  "aceptada_por_sunat": false,

  // Human-readable description from SUNAT (null until processed)
  "sunat_description": null,

  // Additional SUNAT notes (null until processed)
  "sunat_note": null,

  // SUNAT response code (null until processed, "0" when accepted)
  "sunat_responsecode": null,

  // SOAP error message from SUNAT if any (empty string if no error)
  "sunat_soap_error": "",

  // URL to download PDF of void summary
  "enlace_del_pdf": "https://www.nubefact.com/anulacion/b7fc0c001-b31a.pdf",

  // URL to download XML of void summary
  "enlace_del_xml": "https://www.nubefact.com/anulacion/b7fc0c001-b31a.xml",

  // URL to download CDR (Constancia) of void acceptance from SUNAT
  "enlace_del_cdr": "https://www.nubefact.com/anulacion/b7fc0c001-b31a.cdr"
}
