{
  // Operation type - always "generar_comprobante" for creating invoices/receipts/notes
  "operacion": "generar_comprobante",

  // Document type: 1=Factura, 2=Boleta, 3=Nota de Crédito, 4=Nota de Débito
  "tipo_de_comprobante": 1,

  // Series - starts with "F" for Facturas, "B" for Boletas (4 characters exact)
  "serie": "FFF1",

  // Sequential number without leading zeros (1-8 digits)
  "numero": 1,

  // SUNAT transaction type: 1=Venta Interna, 2=Exportación, 30=Detracción, etc.
  "sunat_transaction": 1,

  // Client document type: 6=RUC, 1=DNI, 4=Carnet Extranjería, 7=Pasaporte, etc.
  "cliente_tipo_de_documento": 6,

  // Client document number (1-15 chars)
  "cliente_numero_de_documento": "20600695771",

  // Client full name or business name (1-100 chars)
  "cliente_denominacion": "NUBEFACT SA",

  // Client full address (1-150 chars)
  "cliente_direccion": "CALLE LIBERTAD 116 MIRAFLORES - LIMA - PERU",

  // Primary client email - must be valid format (1-250 chars)
  "cliente_email": "tucliente@gmail.com",

  // Additional email 1 (optional, 1-250 chars)
  "cliente_email_1": "",

  // Additional email 2 (optional, 1-250 chars)
  "cliente_email_2": "",

  // Issue date in format DD-MM-YYYY
  "fecha_de_emision": "09-05-2017",

  // Due date in format DD-MM-YYYY (optional)
  "fecha_de_vencimiento": "",

  // Currency: 1=PEN (Soles), 2=USD (Dólares)
  "moneda": 1,

  // Exchange rate - required if currency is USD (numeric)
  "tipo_de_cambio": "",

  // IGV percentage - typically 18.00 (numeric)
  "porcentaje_de_igv": 18,

  // Global discount amount (numeric, optional)
  "descuento_global": "",

  // Total discount amount (numeric)
  "total_descuento": "",

  // Total advance payment amount (numeric, optional)
  "total_anticipo": "",

  // Total taxable amount (numeric, required for gravada operations)
  "total_gravada": 600,

  // Total unaffected amount (numeric, optional)
  "total_inafecta": "",

  // Total exempt amount (numeric, optional)
  "total_exonerada": "",

  // Total IGV amount (numeric)
  "total_igv": 108,

  // Total free/complimentary amount (numeric, optional)
  "total_gratuita": "",

  // Total other charges (numeric, optional)
  "total_otros_cargos": "",

  // Final total amount including taxes (numeric, required)
  "total": 708,

  // Perception type code (string, optional)
  "percepcion_tipo": "",

  // Perception taxable base (numeric, optional)
  "percepcion_base_imponible": "",

  // Total perception amount (numeric, optional)
  "total_percepcion": "",

  // Total including perception (numeric, optional)
  "total_incluido_percepcion": "",

  // Retention type code (string, optional)
  "retencion_tipo": "",

  // Retention taxable base (numeric, optional)
  "retencion_base_imponible": "",

  // Total retention amount (numeric, optional)
  "total_retencion": "",

  // Total plastic bag tax (numeric, optional)
  "total_impuestos_bolsas": "",

  // Whether operation is subject to detraction (boolean)
  "detraccion": false,

  // Additional notes or observations (string, optional)
  "observaciones": "",

  // For credit/debit notes: document type being modified (1-4)
  "documento_que_se_modifica_tipo": "",

  // For credit/debit notes: series of document being modified
  "documento_que_se_modifica_serie": "",

  // For credit/debit notes: number of document being modified
  "documento_que_se_modifica_numero": "",

  // Credit note reason code (1-13, required for credit notes)
  "tipo_de_nota_de_credito": "",

  // Debit note reason code (1-3, required for debit notes)
  "tipo_de_nota_de_debito": "",

  // Auto-send to SUNAT (boolean) - if true, sends immediately
  "enviar_automaticamente_a_la_sunat": true,

  // Auto-send PDF to client email (boolean)
  "enviar_automaticamente_al_cliente": false,

  // Payment terms/conditions (string, optional)
  "condiciones_de_pago": "",

  // Payment method description (string, optional)
  "medio_de_pago": "",

  // Vehicle license plate (string, optional)
  "placa_vehiculo": "",

  // Purchase order or service order reference (string, optional)
  "orden_compra_servicio": "",

  // PDF format: "" (default A4), "A5", or "TICKET"
  "formato_de_pdf": "",

  // Whether this is issued as contingency (boolean)
  "generado_por_contingencia": "",

  // Goods from jungle region flag (boolean)
  "bienes_region_selva": "",

  // Services from jungle region flag (boolean)
  "servicios_region_selva": "",

  // Array of line items (required, at least 1 item)
  "items": [
    {
      // Unit of measure code (NIU, ZZ, etc.)
      "unidad_de_medida": "NIU",

      // Internal product/service code
      "codigo": "001",

      // SUNAT product code (8 digits, optional)
      "codigo_producto_sunat": "10000000",

      // Product/service description (string, required)
      "descripcion": "DETALLE DEL PRODUCTO",

      // Quantity (numeric, required)
      "cantidad": 1,

      // Unit value without taxes (numeric, required)
      "valor_unitario": 500,

      // Unit price including taxes (numeric, required)
      "precio_unitario": 590,

      // Discount per item (numeric, optional)
      "descuento": "",

      // Subtotal without taxes (numeric, required)
      "subtotal": 500,

      // IGV type: 1=Gravada, 2=Exonerada, 3=Inafecta, etc.
      "tipo_de_igv": 1,

      // IGV amount for this item (numeric)
      "igv": 90,

      // Total including taxes (numeric, required)
      "total": 590,

      // Whether this is advance payment regularization (boolean)
      "anticipo_regularizacion": false,

      // Advance payment document series (required if anticipo_regularizacion=true)
      "anticipo_documento_serie": "",

      // Advance payment document number (required if anticipo_regularizacion=true)
      "anticipo_documento_numero": ""
    },
    {
      "unidad_de_medida": "ZZ",
      "codigo": "001",
      "codigo_producto_sunat": "20000000",
      "descripcion": "DETALLE DEL SERVICIO",
      "cantidad": 5,
      "valor_unitario": 20,
      "precio_unitario": 23.6,
      "descuento": "",
      "subtotal": 100,
      "tipo_de_igv": 1,
      "igv": 18,
      "total": 118,
      "anticipo_regularizacion": false,
      "anticipo_documento_serie": "",
      "anticipo_documento_numero": ""
    }
  ],

  // Array of related delivery guides (optional)
  "guias": [
    {
      // Guide type code
      "guia_tipo": 1,

      // Guide series and number (e.g., "0001-23")
      "guia_serie_numero": "0001-23"
    }
  ],

  // Credit sale installment schedule (optional, required if selling on credit)
  "venta_al_credito": [
    {
      // Installment number
      "cuota": 1,

      // Payment date in format DD-MM-YYYY
      "fecha_de_pago": "11-03-2021",

      // Installment amount (numeric)
      "importe": 600
    },
    {
      "cuota": 2,
      "fecha_de_pago": "11-04-2021",
      "importe": 100
    },
    {
      "cuota": 3,
      "fecha_de_pago": "11-05-2021",
      "importe": 8
    }
  ]
}
